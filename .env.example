PORT=3000

# ============================================================
# MULTI-TENANT CONFIGURATION
# ============================================================
# Unique identifier for this tenant/deployment instance.
# Each deployment should have a unique TENANT_ID.
# If not set, defaults to 'default'.
# Examples: "pbs", "acme", "client-x"
TENANT_ID=default

# ============================================================
# ADMIN CONFIGURATION
# ============================================================
ADMIN_API_KEY=your-admin-api-key-here
# Comma-separated list of admin emails (Supabase Auth users)
ADMIN_EMAILS=admin@example.com

# CORS allowed origins (comma-separated)
# For Vercel: set to your deployment URL, e.g. https://your-app.vercel.app
# Use * to allow all origins (not recommended for production)
ALLOWED_ORIGINS=http://localhost:3000

# ============================================================
# GOOGLE OAUTH2 CREDENTIALS
# ============================================================
# Each tenant needs its own Google OAuth credentials
# pointing to its own Gmail inbox for email routing
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
# For Vercel: set to https://your-app.vercel.app/oauth2callback
# If not set or contains 'localhost', the app will auto-detect from request URL
# IMPORTANT: This URI must also be added to Google Cloud Console > Credentials > Authorized redirect URIs
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth2callback

# Maximum messages to fetch per request
MAX_MESSAGES=20

# ============================================================
# TOKEN ENCRYPTION
# ============================================================
# Optional: 32 hex chars = 16 bytes AES-128 key for encrypting OAuth tokens
TOKEN_ENCRYPTION_KEY=

# Optional: custom path for token file (local storage only)
TOKEN_PATH=

# ============================================================
# SUPABASE CONFIGURATION
# ============================================================
# All tenants share the same Supabase project/database
# Data isolation is handled by tenant_id column in all tables

# Public (client-side) - for admin login UI
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-side (service role) - for data operations
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Table names (defaults shown, can be customized)
SUPABASE_KV_TABLE=app_kv
SUPABASE_TABLE_ALIASES=app_aliases
SUPABASE_TABLE_DOMAINS=app_domains
SUPABASE_TABLE_LOGS=app_logs
SUPABASE_TABLE_AUDIT=app_audit
SUPABASE_TABLE_API_KEYS=app_api_keys
SUPABASE_TABLE_PARTNER_ALIASES=app_partner_aliases
SUPABASE_TABLE_PARTNER_ACCESS_LOGS=app_partner_access_logs

# ============================================================
# PARTNER API CONFIGURATION
# ============================================================
PARTNER_API_ENABLED=true
PARTNER_KEY_PEPPER=
PARTNER_DEFAULT_RATE_LIMIT=60
PARTNER_MAX_WAIT_SECONDS=20
